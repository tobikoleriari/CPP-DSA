   "source": [
    "2. Write a program that asks a user to input the radius then the program calculates the\n",
    "volume of a sphere (the formula for the volume is (4/3) πr\n",
    "3\n",
    "). Use the inbuilt\n",
    "exponential function in C++ to compute (r3\n",
    ")."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "95fbc3b2",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "#include <iostream>\n",
    "#include <cmath>\n",
    "using namespace std;\n",
    "\n",
    "int main(){\n",
    "    int radius;\n",
    "    cout << \"Enter radius of the sphere: \";\n",
    "    cin >> radius;\n",
    "    cout << \"Volume of the sphere: \" << (4.0/3.0) * M_PI * pow(radius, 3) << endl;\n",
    "    return 0;\n",
    "}"
   ]
