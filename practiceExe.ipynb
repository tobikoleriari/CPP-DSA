    "3. Using functions, write a program to compute the area and perimeter of a square.\n",
    "The program should ask the user to enter a number corresponding to the side length\n",
    "of the square and display the area and perimeter of the square."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "367e1a59",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "#include <iostream>\n",
    "\n",
    "using namespace std;\n",
    "double area (double length) {\n",
    "    return length * length;\n",
    "}\n",
    "double perimeter(double length){\n",
    "    return length *4;\n",
    "}\n",
    "\n",
    "int main (){\n",
    "double length;\n",
    "cout <<\"enter the length of the square: \";  \n",
    "cin >> length;\n",
    "cout << \"Area = \" << area(length) << endl;\n",
    "cout << \"Perimeter = \" <<perimeter(length) << endl; \n",
    "return 0;\n",
    "}"
   ]
