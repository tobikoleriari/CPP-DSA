    "5. The following is pseudocode for a program being designed. Write the C++ program\n",
    "equivalent of the same.\n",
    "\n",
    "BEGIN\n",
    "\n",
    "SET x TO 0, y TO 20\n",
    "\n",
    "REPEAT\n",
    "\n",
    "SUBTRACT 4 FROM y\n",
    "\n",
    "ADD 2/y TO x\n",
    "\n",
    "UNTIL\n",
    "\n",
    "y IS LESS THAN 6\n",
    "\n",
    "DISPLAY x\n",
    "\n",
    "END\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2003565f",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "#include <iostream>\n",
    "using namespace std;\n",
    "\n",
    "int main(){\n",
    "    double x = 0;\n",
    "    double y = 20;\n",
    " do {\n",
    "    y=y-4; \n",
    "    x=x+ (2.0/y);\n",
    " }\n",
    "    while (y>6);\n",
    "\n",
    "cout << \"x = \" << x << endl;\n",
    "return 0;\n",
    "}"
   ]
  },
