    "1. Write a program that asks the user for the number of days. The program then prints\n",
    "out the number of seconds in the number of days given."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "687ea3a4",
   "metadata": {
    "vscode": {
     "languageId": "plaintext"
    }
   },
   "outputs": [],
   "source": [
    "#include <iostream>\n",
    "using namespace std;\n",
    "\n",
    "int main(){\n",
    "    int days;\n",
    "    cout << \"Enter number of days: \";\n",
    "    cin >> days;\n",
    "    cout << \"Number of seconds: \" << days * 24 *60 * 60<< endl;\n",
    "    return 0;\n",
    "}"
   ]
  },
